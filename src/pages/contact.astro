---
import MarketingChrome from "../layouts/MarketingChrome.astro";
import ScheduleDemoIsland from "../components/marketing/ScheduleDemoIsland.vue";
import contact from "../content/home/contact.json";

const title = "Contact · Bolt TMS";
const description =
    "Reach Bolt sales and support by phone or email. Real people in Nashville, same-day on new conversations, sub-hour on production issues.";

const withBase = (path: string) => {
    const base = import.meta.env.BASE_URL || "/";
    const root = base.replace(/\/$/, "");
    const p = path.startsWith("/") ? path : `/${path}`;
    return root ? `${root}${p}` : p;
};

const scheduleHeroButtonClass =
    "marketing-secondary-cta inline-flex h-11 w-full min-w-0 items-center justify-center rounded-full border px-6 text-[14px] font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#facc15] sm:w-auto";

const scheduleStripButtonClass =
    "marketing-secondary-cta inline-flex h-11 items-center justify-center rounded-full border px-6 text-[14px] font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#facc15]";

const salesBestFor = [
    "Pricing for your fleet shape",
    "Walkthroughs and field-test setup",
    "Onboarding fit for your operation",
    "Brokerage add-on questions",
];

const supportBestFor = [
    "Live dispatch issues during a shift",
    "ELD, telematics, or accounting connection help",
    "Driver app, settlement, and billing questions",
    "Account changes for active customers",
];

const conversations = [
    {
        q: "How long is implementation?",
        a: "Most teams are dispatching in days, not months. The 30-day field test is your real freight on your real lanes.",
    },
    {
        q: "Do you sell to brokers?",
        a: "Yes. The brokerage add-on is +$200/mo and runs alongside the asset-based product on the same record.",
    },
    {
        q: "Is there a long-term contract?",
        a: "No. The 30-day field test is the only commitment. After that it’s month-to-month with no auto-renew lock-in.",
    },
    {
        q: "Will my QuickBooks / Samsara data flow in?",
        a: "QuickBooks Online and Samsara are among the first native connectors. Other ELDs and accounting layers connect through the same handoff pattern.",
    },
];
---

<MarketingChrome title={title} description={description}>
    <section class="contact-hero relative z-10 isolate overflow-hidden py-10 sm:py-12">
        <div
            class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[520px] bg-[radial-gradient(circle_at_50%_12%,rgba(255,255,255,0.14),rgba(255,255,255,0.05)_28%,rgba(5,6,6,0)_62%)]"
            aria-hidden="true"
        />
        <div
            class="pointer-events-none absolute inset-x-0 top-16 -z-10 mx-auto h-[280px] max-w-3xl rounded-full bg-white/[0.035] blur-3xl"
            aria-hidden="true"
        />

        <div class="marketing-shell">
        <article class="relative max-w-3xl">
            <span
                class="landing-hero-pill mb-7 inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/[0.04] px-3 py-1.5 text-[11px] font-medium uppercase tracking-[0.18em] text-white/65 backdrop-blur"
            >
                <span class="landing-hero-pulse relative flex size-2">
                    <span class="absolute inset-0 rounded-full bg-emerald-400/45" aria-hidden="true"></span>
                    <span class="relative size-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
                </span>
                Contact
            </span>
            <h1
                class="max-w-[760px] text-balance font-semibold leading-[0.96] tracking-tight text-white"
                style="font-size: clamp(2.35rem, 4vw, 3.5rem)"
            >
                Real people. Same time zone. Same software you’re running.
            </h1>
            <p class="mt-6 max-w-xl text-pretty text-[16px] leading-relaxed text-white/55 sm:text-[18px]">
                We’re a small team in Nashville. The phones are answered by people who know the
                product — not a routing menu, not a ticket queue. Pick the lane that fits.
            </p>
            <p
                class="mt-6 max-w-xl border-l-2 border-[#facc15]/55 pl-5 text-[15px] leading-relaxed text-white/62 sm:text-[16px]"
            >
                Trying to decide if Bolt is right for your operation? You don’t need to call. The
                30-day field test is on your freight, on your lanes, with no contract.
            </p>

            <div
                class="mt-8 flex w-full max-w-xl flex-col items-stretch gap-3 sm:max-w-none sm:flex-row sm:flex-wrap sm:items-start"
            >
                <div class="w-full sm:w-auto">
                    <ScheduleDemoIsland
                        client:load
                        theme="light"
                        abbreviateOnNarrow={false}
                        label="Schedule a walkthrough"
                        buttonClass={scheduleHeroButtonClass}
                    />
                </div>
                <a
                    href="https://app.bolttms.com/register?step=registration"
                    class="landing-cta inline-flex h-11 w-full items-center justify-center rounded-full bg-white px-6 text-[14px] font-medium text-black shadow-xs transition hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#facc15] sm:w-auto"
                >
                    Start your field test
                </a>
            </div>

            <dl
                class="mt-12 grid w-full max-w-xl grid-cols-3 gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] text-left backdrop-blur sm:max-w-2xl"
            >
                <div class="pricing-hero-stat">
                    <dt class="pricing-hero-stat-label">New conversations</dt>
                    <dd class="pricing-hero-stat-value">Same<span class="pricing-hero-stat-suffix">day</span></dd>
                </div>
                <div class="pricing-hero-stat">
                    <dt class="pricing-hero-stat-label">Production issues</dt>
                    <dd class="pricing-hero-stat-value">&lt;1<span class="pricing-hero-stat-suffix">hr</span></dd>
                </div>
                <div class="pricing-hero-stat">
                    <dt class="pricing-hero-stat-label">Hours · Mon–Fri</dt>
                    <dd class="pricing-hero-stat-value">7–7<span class="pricing-hero-stat-suffix">CT</span></dd>
                </div>
            </dl>
        </article>
        </div>
    </section>

    <section
        class="marketing-shell relative z-10 mt-14 border-t border-white/10 pt-12"
        aria-labelledby="contact-channels-heading"
    >
        <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-white/40">
            Pick the right line
        </p>
        <h2
            id="contact-channels-heading"
            class="mt-5 text-xl font-semibold tracking-tight text-white sm:text-2xl"
        >
            Two ways in. Both go to a person.
        </h2>

        <div class="contact-channel-grid mt-10">
            <article class="contact-channel-card contact-channel-card--sales">
                <header class="contact-channel-card-head">
                    <span class="contact-channel-icon" aria-hidden="true">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="size-[18px]"
                        >
                            <path
                                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                            />
                        </svg>
                    </span>
                    <div>
                        <p class="contact-channel-eyebrow">Sales</p>
                        <p class="contact-channel-meta">For new conversations and field tests</p>
                    </div>
                </header>

                <div class="contact-channel-rows">
                    <a
                        href={contact.sales.phoneHref}
                        class="contact-channel-primary"
                    >
                        {contact.sales.phoneDisplay}
                    </a>
                    <a
                        href={contact.sales.emailHref}
                        class="contact-channel-secondary"
                    >
                        {contact.sales.emailDisplay}
                    </a>
                </div>

                <p class="contact-channel-response">
                    <span class="contact-channel-response-tag">Response</span>
                    Same business day. Usually faster.
                </p>

                <div class="contact-channel-best-for">
                    <p class="contact-channel-best-for-label">Best for</p>
                    <ul class="contact-channel-best-for-list">
                        {
                            salesBestFor.map((item) => (
                                <li>
                                    <span class="contact-channel-bullet" aria-hidden="true" />
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </article>

            <article class="contact-channel-card">
                <header class="contact-channel-card-head">
                    <span class="contact-channel-icon" aria-hidden="true">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="size-[18px]"
                        >
                            <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
                            <path d="M21 19a2 2 0 0 1-2 2h-1v-7h3z" />
                            <path d="M3 19a2 2 0 0 0 2 2h1v-7H3z" />
                        </svg>
                    </span>
                    <div>
                        <p class="contact-channel-eyebrow">Support</p>
                        <p class="contact-channel-meta">For active customers running freight</p>
                    </div>
                </header>

                <div class="contact-channel-rows">
                    <a
                        href={contact.support.phoneHref}
                        class="contact-channel-primary"
                    >
                        {contact.support.phoneDisplay}
                    </a>
                    <a
                        href={contact.support.emailHref}
                        class="contact-channel-secondary"
                    >
                        {contact.support.emailDisplay}
                    </a>
                </div>

                <p class="contact-channel-response">
                    <span class="contact-channel-response-tag">Response</span>
                    Production issues: under one hour during business hours.
                </p>

                <div class="contact-channel-best-for">
                    <p class="contact-channel-best-for-label">Best for</p>
                    <ul class="contact-channel-best-for-list">
                        {
                            supportBestFor.map((item) => (
                                <li>
                                    <span class="contact-channel-bullet" aria-hidden="true" />
                                    {item}
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </article>
        </div>
    </section>

    <section
        class="marketing-shell relative z-10 mt-14 grid gap-6 border-t border-white/10 pt-12 lg:grid-cols-12 lg:gap-10"
        aria-labelledby="contact-where-heading"
    >
        <div class="lg:col-span-5">
            <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-white/40">
                Where we are
            </p>
            <h2
                id="contact-where-heading"
                class="mt-5 text-xl font-semibold tracking-tight text-white sm:text-2xl"
            >
                Built in Nashville. Same time zone as most of your dispatch.
            </h2>
            <p class="mt-6 text-[16px] leading-7 text-white/64">
                We’re a workshop, not a sales floor. Engineers, dispatch advisors, and the people
                who answer the phone all sit in the same room — which is why product feedback turns
                into ship dates instead of tickets.
            </p>
        </div>

        <div class="contact-office-card lg:col-span-7">
            <div class="contact-office-card-head">
                <span class="contact-office-icon" aria-hidden="true">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="size-[18px]"
                    >
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                </span>
                <div>
                    <p class="contact-office-eyebrow">Headquarters</p>
                    <p class="contact-office-name">Nashville, Tennessee</p>
                </div>
            </div>
            <dl class="contact-office-grid">
                <div>
                    <dt>Time zone</dt>
                    <dd>Central · UTC−6 / UTC−5</dd>
                </div>
                <div>
                    <dt>Founded</dt>
                    <dd>2021 · Trucking-native team</dd>
                </div>
                <div>
                    <dt>Phones</dt>
                    <dd>Picked up by people who built the product</dd>
                </div>
                <div>
                    <dt>Press &amp; partnerships</dt>
                    <dd>
                        <a href={contact.sales.emailHref} class="contact-office-link"
                            >{contact.sales.emailDisplay}</a
                        >
                    </dd>
                </div>
            </dl>
        </div>
    </section>

    <section
        class="marketing-shell relative z-10 mt-14 border-t border-white/10 pt-12"
        aria-labelledby="contact-faq-heading"
    >
        <p class="text-[12px] font-semibold uppercase tracking-[0.2em] text-white/40">
            Before you call
        </p>
        <h2
            id="contact-faq-heading"
            class="mt-5 text-xl font-semibold tracking-tight text-white sm:text-2xl"
        >
            A few things people usually ask first.
        </h2>

        <ul class="contact-faq-list mt-10">
            {
                conversations.map((row) => (
                    <li class="contact-faq-row">
                        <p class="contact-faq-q">{row.q}</p>
                        <p class="contact-faq-a">{row.a}</p>
                    </li>
                ))
            }
        </ul>

        <div class="landing-section-cta mt-12">
            <div class="landing-section-cta-text">
                <p class="landing-section-cta-eyebrow">Or skip the call</p>
                <p class="landing-section-cta-headline">
                    The fastest way to know if Bolt fits is to run it for a week.
                </p>
            </div>
            <div class="landing-section-cta-actions">
                <a
                    href="https://app.bolttms.com/register?step=registration"
                    class="landing-cta inline-flex h-11 items-center justify-center rounded-full bg-white px-6 text-[14px] font-medium text-black shadow-xs transition hover:bg-white/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#facc15]"
                >
                    Start your field test
                </a>
                <a
                    href={withBase("/pricing")}
                    class="marketing-secondary-cta inline-flex h-11 items-center justify-center rounded-full border px-6 text-[14px] font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#facc15]"
                >
                    See pricing
                </a>
                <ScheduleDemoIsland
                    client:load
                    theme="light"
                    abbreviateOnNarrow={false}
                    buttonClass={scheduleStripButtonClass}
                />
            </div>
        </div>
    </section>
</MarketingChrome>
