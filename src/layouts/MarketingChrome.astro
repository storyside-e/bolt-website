---
import "../styles/global.css";
import MarketingChromeShell from "../components/marketing/MarketingChromeShell.astro";

type Props = {
    title: string;
    description?: string;
};

const {
    title,
    description = "Bolt TMS for trucking carriers — self-serve and live in an hour.",
} = Astro.props;

const iconHref = `${import.meta.env.BASE_URL}favicon.ico`.replace(/\/+/g, "/");
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/x-icon" href={iconHref} />
        <title>{title}</title>
    </head>
    <body>
        <div
            id="landing-top"
            class="landing-page landing-light min-h-screen overflow-x-hidden bg-[#050606] text-white"
        >
            <script is:inline>
                (function () {
                    try {
                        var stored = localStorage.getItem("bolt-landing-theme");
                        if (stored === "dark") {
                            var el = document.getElementById("landing-top");
                            if (el) {
                                el.classList.remove("landing-light");
                                el.classList.add("landing-dark");
                            }
                        }
                    } catch (_) {}
                })();
            </script>
            <MarketingChromeShell currentPath={currentPath}>
                <main
                    class="landing-main marketing-subpage-main relative z-10 pt-7 pb-12 sm:pt-8 sm:pb-12"
                >
                    <slot />
                </main>
            </MarketingChromeShell>
        </div>
    </body>
</html>
